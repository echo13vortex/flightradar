# FlightRadar – proměnné prostředí
# Zkopíruj jako .env a vyplň hodnoty

# ── Travelpayouts / Aviasales Data API ─────────────────────────────────────────
# Registrace zdarma: https://www.travelpayouts.com → Data API → API token
TRAVELPAYOUTS_TOKEN=tvuj_token_zde

# ── Amadeus API (volitelné, momentálně vypnuté) ─────────────────────────────────
# Registrace zdarma: https://developers.amadeus.com
AMADEUS_API_KEY=tvuj_api_key_zde
AMADEUS_API_SECRET=tvuj_api_secret_zde
AMADEUS_ENV=test

# ── Databáze ───────────────────────────────────────────────────────────────────
# SQLite (výchozí, bez serveru):
DATABASE_URL=sqlite:///flightradar.db

# PostgreSQL (pro VPS):
# DATABASE_URL=postgresql://user:heslo@localhost:5432/flightradar

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=8002

# ── Ostatní ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
